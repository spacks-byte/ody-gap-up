FUTU_PORT=11111
MARKET=HK
SCAN_INTERVAL=300
PERPLEXITY_API_KEY=your-perplexity-api-key

# Jo's tracker script (/joslist)
GOOGLE_SHEET_URL=your-google-sheet-url
GOOGLE_CREDENTIALS_FILE=service-account.json
